+GIT_INLINE(DWORD) get_multi_byte_to_wide_chars_flags(void) {
+	static char inited = 0;
+	static DWORD flags;
+
+	/* Invalid code point check supported on 2k sp4+ only */
+	if(!inited) {
+		flags = git_has_win32_version(5, 0, 4) ? MB_ERR_INVALID_CHARS : 0;
+		inited = 1;
+	}
+
+	return flags;
+}
